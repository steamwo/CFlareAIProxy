# The SPA shell must never remain stale across deployments, otherwise it can
# reference Vite chunks that no longer exist in the latest Worker version.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/admin
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/admin/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/admin/:route
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Vite fingerprints generated assets, so these files are safe to cache forever.
/admin/assets/*
  Cache-Control: public, max-age=31536000, immutable
